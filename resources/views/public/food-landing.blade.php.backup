lute;inset:auto -10% -24% auto;width:210px;height:210px;border-radius:999px;background:radial-gradient(circle,rgba(255,255,255,.16),transparent 70%)}.gm-promo[data-tone='gold']{background:linear-gradient(160deg,#2d1d11,#8c5f1c)}.gm-promo[data-tone='ember']{background:linear-gradient(160deg,#2a130e,#8b2f20)}.gm-promo[data-tone='cream']{background:linear-gradient(160deg,#403126,#b68d58)}.gm-promo small{display:block;position:relative;z-index:1;font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:rgba(245,236,221,.58)}.gm-promo h3{position:relative;z-index:1;margin-top:14px;font-family:'Prata',serif;font-size:clamp(28px,3vw,40px);line-height:1.02;max-width:9ch}.gm-promo p{position:relative;z-index:1;margin-top:14px;color:var(--gm-muted);line-height:1.68;max-width:28ch}.gm-service{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:18px;margin-top:32px}.gm-note{padding:22px;border-radius:28px;background:rgba(255,255,255,.78);border:1px solid rgba(33,24,19,.08);box-shadow:0 16px 40px rgba(33,24,19,.1)}.gm-note strong{display:block;font-size:34px;line-height:1;color:#8a2f1b}.gm-note h3{margin-top:18px;font-size:24px;line-height:1.08}.gm-note p{margin-top:12px;color:rgba(33,24,19,.72);line-height:1.68}.gm-rosterHead{display:flex;justify-content:space-between;gap:20px;align-items:end}.gm-roster{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:18px;margin-top:30px}.gm-rosterCard{padding:22px;border-radius:28px;background:rgba(255,255,255,.82);border:1px solid rgba(33,24,19,.08);box-shadow:0 16px 44px rgba(33,24,19,.1)}.gm-rosterCardTop{display:flex;justify-content:space-between;gap:14px;align-items:flex-start}.gm-rosterCard h3{margin:0;font-size:24px;line-height:1.08}.gm-badge{display:inline-flex;padding:8px 11px;border-radius:999px;background:rgba(214,162,69,.14);font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:#85591a;white-space:nowrap}.gm-rosterCard p,.gm-rosterMeta{color:rgba(33,24,19,.72);line-height:1.62}.gm-rosterMeta{display:grid;gap:10px;margin-top:16px;font-size:15px}.gm-rosterCard a{display:inline-flex;margin-top:18px;color:#8a2f1b;font-weight:800}.gm-close{margin-top:34px;padding:30px;border-radius:34px;background:linear-gradient(135deg,rgba(214,162,69,.16),rgba(99,171,200,.14),rgba(187,75,45,.18));border:1px solid rgba(33,24,19,.08);box-shadow:0 22px 58px rgba(33,24,19,.12)}.gm-closeGrid{display:grid;grid-template-columns:1fr auto;gap:20px;align-items:end}.gm-close h2{margin:0;font-family:'Prata',serif;font-size:clamp(38px,5vw,68px);line-height:.98;max-width:10ch}.gm-close p{margin-top:18px;max-width:620px;color:rgba(33,24,19,.72);line-height:1.74;font-size:17px}.gm-closingBadge{padding:22px;border-radius:28px;background:rgba(255,255,255,.64);display:grid;gap:14px;justify-items:center;text-align:center}.gm-closingBadge img{width:96px;height:96px;border-radius:24px;object-fit:cover;box-shadow:0 18px 34px rgba(0,0,0,.14)}.gm-reveal{opacity:0;transform:translateY(28px);transition:opacity .78s ease,transform .78s ease}.gm-reveal.is-visible{opacity:1;transform:none}@keyframes gm-scroll{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}@media(max-width:1100px){.gm-heroGrid,.gm-stageGrid,.gm-menuStage,.gm-closeGrid{grid-template-columns:1fr}.gm-strip,.gm-promoGrid,.gm-service,.gm-roster{grid-template-columns:repeat(2,minmax(0,1fr))}.gm-rosterHead{flex-direction:column;align-items:flex-start}}@media(max-width:760px){.gm-nav .gm-wrap,.gm-links,.gm-actions{flex-direction:column;align-items:flex-start}.gm-strip,.gm-promoGrid,.gm-service,.gm-roster{grid-template-columns:1fr}.gm-section,.gm-hero{padding-top:74px;padding-bottom:74px}.gm-logoPoster img{max-width:220px}}
